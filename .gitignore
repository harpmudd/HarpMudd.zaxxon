# ── FPGA build intermediates (regenerated by Quartus compilation) ─────────────
src/fpga/db/
src/fpga/incremental_db/
src/fpga/output_files/
src/fpga/ap_core_assignment_defaults.qdf
src/fpga/c5_pin_model_dump.txt
*.qws
*.rpt
*.summary
*.smsg
*.jdi

# ── Build logs ────────────────────────────────────────────────────────────────
quartus_build.log
compile.log

# ── Upstream reference checkouts / local tooling (not part of the port) ───────
mister_source/
tools/
.claude/

# ── Python bytecode cache ─────────────────────────────────────────────────────
__pycache__/
*.pyc

# ── ROMs & extracted ROM data — NEVER commit copyrighted data ─────────────────
# The Pocket distribution (Cores/Assets/Platforms, possibly under dist/) IS
# committed: bitstream + JSON/artwork (icon.bin etc.) + per-game instance JSONs.
# Only ROM images and ROM data extracted into the source are excluded.
*.rom
*.zip
*.hex
*.mif
# Digitized sound samples (copyrighted audio, ~782 KB WAV blob -> SDRAM). Users
# build these locally from their own MiSTer .mra via pack_rom.py. NOT the artwork
# .bin (icon.bin / Platforms/_images/*.bin), which stay tracked.
*_samples.bin
*.wav
